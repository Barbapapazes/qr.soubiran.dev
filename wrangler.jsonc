{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "qr-soubiran-dev",
  "compatibility_date": "2026-04-15",
  "routes": [
    {
      "pattern": "qr.soubiran.dev",
      "zone_name": "soubiran.dev",
      "custom_domain": true
    }
  ],
  "workers_dev": true,
  "assets": {
    "not_found_handling": "single-page-application"
  }
}
